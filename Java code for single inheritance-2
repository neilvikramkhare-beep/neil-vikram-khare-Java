class Shape {
    public void area() {
        System.out.println("Display area.");
    }
}
class Triangle extends Shape {
    public void area(int l, int h) {
        System.out.println(0.5 * l * h);
    }
}
class Main { 
    public static void main(String args[]) { 
        Triangle myTriangle = new Triangle();
        myTriangle.area();
        myTriangle.area(6, 4);
    } 
}

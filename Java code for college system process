import java.util.List;
import java.util.ArrayList;
class College {
    private String name;
    private List<Student> students;
    private List<Course> courses;
    public College(String name) {
        this.name = name;
        this.students = new ArrayList<>();
        this.courses = new ArrayList<>();
    }
    public void addStudent(Student student) {
        students.add(student);
    }
    public void addCourse(Course course) {
        courses.add(course);
    }
    @Override
    public String toString() {
        return "College: " + name + "\nStudents: " + students + "\nCourses: " + courses;
    }
}
class Student {
    private String name;
    private int age;
    private List<Course> enrolledCourses;
    public Student(String name, int age) {
        this.name = name;
        this.age = age;
        this.enrolledCourses = new ArrayList<>();
    }
    public void enrollInCourse(Course course) {
        enrolledCourses.add(course);
    }
    @Override
    public String toString() {
        return "Student: " + name + ", Age: " + age + ", Enrolled Courses: " + enrolledCourses;
    }
}
class Course {
    private String code;
    private String title;
    public Course(String code, String title) {
        this.code = code;
        this.title = title;
    }
    @Override
    public String toString() {
        return "Course: " + code + " - " + title;
    }
}
public class CollegeSystem {
    public static void main(String[] args) {
        College college = new College("ABC College");
        Student student1 = new Student("John Doe", 20);
        Student student2 = new Student("Jane Smith", 22);
        Course course1 = new Course("CS101", "Introduction to Computer Science");
        Course course2 = new Course("MATH201", "Calculus II");
        college.addStudent(student1);
        college.addStudent(student2);
        college.addCourse(course1);
        college.addCourse(course2);
        student1.enrollInCourse(course1);
        student2.enrollInCourse(course2);
        System.out.println(college);
    }
}

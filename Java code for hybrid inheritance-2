class OOP { 
    void display() { 
        System.out.println("Hello, World!"); 
    } 
} 
class A extends OOP { 
    @Override
    void display() { 
        System.out.println("Class A"); 
    } 
} 
class B extends OOP { 
    @Override
    void display() { 
        System.out.println("Class B"); 
    } 
}
class C extends A { 
    @Override
    void display() { 
        System.out.println("Class C"); 
    } 
} 
class D extends B { 
    @Override
    void display() { 
        System.out.println("Class D"); 
    } 
} 
class E extends C { 
    @Override
    void display() { 
        System.out.println("Class E"); 
    } 
}
public class Main {
    public static void main(String[] args) { 
        E obj = new E(); 
        obj.display(); 
        A a = new A(); 
        a.display(); 
    }
}

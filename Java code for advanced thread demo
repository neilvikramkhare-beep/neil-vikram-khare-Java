class BankAccount {
    private int balance = 0;
    private boolean isMoneyAvailable = false;
    public synchronized void withdraw(int amount) {
        System.out.println(Thread.currentThread().getName() + " is waiting to withdraw...");
        while (!isMoneyAvailable) {
            try {
                wait(); 
            } catch (InterruptedException e) {
                System.err.println("Withdrawal interrupted.");
            }
        }
        if (balance >= amount) {
            balance -= amount;
            System.out.println(Thread.currentThread().getName() + " withdrew " + amount + ". Remaining: " + balance);
        }
        isMoneyAvailable = false;
    }
    public synchronized void deposit(int amount) {
        System.out.println(Thread.currentThread().getName() + " is depositing money...");
        balance += amount;
        isMoneyAvailable = true;
        notify(); 
        System.out.println("Deposit complete. Notification sent.");
    }
}
public class AdvancedThreadDemo {
    @SuppressWarnings("removal") 
    public static void main(String[] args) {
        BankAccount account = new BankAccount();
        Thread withdrawThread = new Thread(() -> {
            account.withdraw(500);
        }, "Withdraw-Thread");
        Thread depositThread = new Thread(() -> {
            try { Thread.sleep(2000); } catch (InterruptedException e) {}
            account.deposit(500);
        }, "Deposit-Thread");
        withdrawThread.start();
        depositThread.start();
        try {
            Thread.sleep(500);
            System.out.println("--- Suspending Deposit-Thread manually ---");
            depositThread.suspend();
            Thread.sleep(2000);
            System.out.println("--- Resuming Deposit-Thread manually ---");
            depositThread.resume();  
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
        try {
            withdrawThread.join();
            depositThread.join();
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
        System.out.println("Main execution finished.");
    }
}

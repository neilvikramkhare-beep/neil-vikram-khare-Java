import java.util.List;
import java.util.ArrayList;
import java.util.Queue;
import java.util.LinkedList;
class QueueChatApp {
    private List<ChatRoom> chatRooms;
        public QueueChatApp() {
            chatRooms = new ArrayList<>();
        }
        public void createChatRoom(String roomName) {
            ChatRoom chatRoom = new ChatRoom(roomName);
            chatRooms.add(chatRoom);
        }
        public ChatRoom getChatRoom(String roomName) {
            for (ChatRoom chatRoom : chatRooms) {
                if (chatRoom.getRoomName().equals(roomName)) {
                    return chatRoom;
                }
            }
            return null;
        }
        public void start() {
            System.out.println("Chat application started.");
        }
        public void stop() {
            System.out.println("Chat application stopped.");
        }
        public static void main(String[] args) {
            QueueChatApp chatApp = new QueueChatApp();
            chatApp.start();
            chatApp.stop();
            chatApp.createChatRoom("General");
            ChatRoom generalRoom = chatApp.getChatRoom("General");
            if (generalRoom != null) {
                User user1 = new User("Alice");
                User user2 = new User("Bob");
                generalRoom.addUser(user1);
                generalRoom.addUser(user2);
                Message message1 = new Message(user1.getUsername(), "Hello, everyone!");
                generalRoom.sendMessage(message1);
                Message receivedMessage = generalRoom.receiveMessage();
                if (receivedMessage != null) {
                    System.out.println(receivedMessage.getSender() + ": " + receivedMessage.getContent());
                } else {
                    System.out.println("No messages in the queue.");
                }
            }
        }
    }
class Message {
        private String sender;
        private String content;
        public Message(String sender, String content) {
            this.sender = sender;
            this.content = content;
        }
        public String getSender() {
            return sender;
        }
        public String getContent() {
            return content;
        }
    }
class User {
        private String username;
        public User(String username) {
            this.username = username;
        }
        public String getUsername() {
            return username;
        }
    }
class ChatQueue {
        private Queue<Message> messageQueue;
        public ChatQueue() {
            messageQueue = new LinkedList<>();
        }
        public void enqueueMessage(Message message) {
            messageQueue.add(message);
        }
        public Message dequeueMessage() {
            return messageQueue.poll();
        }
        public boolean isEmpty() {
            return messageQueue.isEmpty();
        }
    }
class ChatRoom {
        private String roomName;
        private List<User> users;
        private ChatQueue chatQueue;
        public ChatRoom(String roomName) {
            this.roomName = roomName;
            this.users = new ArrayList<>();
            this.chatQueue = new ChatQueue();
        }
        public String getRoomName() {
            return roomName;
        }
        public void addUser(User user) {
            users.add(user);
        }
        public void removeUser(User user) {
            users.remove(user);
        }
        public void sendMessage(Message message) {
            chatQueue.enqueueMessage(message);
        }
        public Message receiveMessage() {
            return chatQueue.dequeueMessage();
        }
    }

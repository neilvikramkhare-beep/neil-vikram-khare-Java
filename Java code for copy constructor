class Student
{
    String name;
    int age;
    public void printName() {
        System.out.println(this.name);
        System.out.println(this.age);
    }
    Student(Student s2) 
    {
        this.name =  s2.name;
        this.age = s2.age;
    }
}
public class OOPS
{
    public static void main(String[] args)
    {
        Student s1 = new Student();
        s1.name =  "Rahul";
        s1.age = 76;
        s1.printName();
        Student s2 = new Student(s1);
        s2.printName();
    }
}

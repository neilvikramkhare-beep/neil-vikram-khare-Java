class Student
{
    String name;
    int age;
    public void printName() {
        System.out.println(this.name);
        System.out.println(this.age);
    }
    Student() 
    {
        System.out.println("The constructor called.");
    }
}
public class OOPS
{
    public static void main(String[] args)
    {
        Student s1 = new Student();
        s1.name = "Rahul";
        s1.age = 78;
        s1.printName();
    }
}

public class StringBuffer
{
    public static void main(String args[])
    {
        StringBuffer sb = new StringBuffer("Hello");
        System.out.println(sb);
        System.out.println(sb.length());
        System.out.println(sb.charAt(1));
        System.out.println(sb.append(" World"));
        System.out.println(sb.insert(5, " Java"));
        System.out.println(sb.delete(5, 10));
        System.out.println(sb.reverse());
        System.out.println(sb.replace(0, 5, "Hi"));
        System.out.println(sb.capacity());
        System.out.println(sb.substring(0, 2));
        System.out.println(sb.toString());
        System.out.println(sb.equals("Hi World"));
        System.out.println(sb.hashCode());
        System.out.println(sb.indexOf("World"));
        System.out.println(sb.lastIndexOf("o"));
        System.out.println(sb.notify());
        System.out.println(sb.notifyAll());
        System.out.println(sb.wait());
        System.out.println(sb.getClass());
        System.out.println(sb.clone());
        System.out.println(sb.getName());
        System.out.println(sb.getSimpleName());
        System.out.println(sb.getCanonicalName());
        System.out.println(sb.add("Hello"));
    }
}

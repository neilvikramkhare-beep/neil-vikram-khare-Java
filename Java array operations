import java.util.Arrays;
public class arrays {
    public static void main(String[] args) {
        int[] myNumbers = {10, 20, 30, 40, 50};
        System.out.println(myNumbers[0]);
        System.out.println(myNumbers.length);
        Arrays.sort(myNumbers);
        System.out.println(myNumbers[0]);
        System.out.println(myNumbers.length - 1);
        System.out.println(myNumbers[myNumbers.length - 1]);
        System.out.println(Arrays.toString(myNumbers));
        System.out.println(Arrays.binarySearch(myNumbers, 30));
        System.out.println(Arrays.equals(myNumbers, new int[]{10, 20, 30, 40, 50}));
        System.out.println(Arrays.toString(myNumbers.clone()));
        System.out.println(Arrays.toString(Arrays.copyOf(myNumbers, myNumbers.length)));
        System.out.println(Arrays.toString(Arrays.copyOfRange(myNumbers, 1, 4)));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).toArray()));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).filter(num -> num > 20).toArray()));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).map(num -> num * 2).toArray()));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).distinct().toArray()));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).sorted().toArray()));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).limit(3).toArray()));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).skip(2).toArray()));
        System.out.println(Arrays.toString(Arrays.stream(myNumbers).toArray()));
        for (int i = 0; i < myNumbers.length; i++) {
            System.out.println(myNumbers[i]);
        }
        for (int num : myNumbers) {
            System.out.println(num);
        }
    }
}

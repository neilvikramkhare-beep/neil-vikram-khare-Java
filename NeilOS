    // =========================
    // TERMINAL PANEL
    // =========================

    private JPanel createTerminalPanel() {
        JPanel panel = new JPanel(new BorderLayout(10, 10));
        panel.setBackground(new Color(30, 30, 40));
        panel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));

        // Terminal Output
        JTextArea terminalArea = new JTextArea(20, 50);
        terminalArea.setBackground(new Color(0, 0, 0));
        terminalArea.setForeground(new Color(0, 255, 0));
        terminalArea.setFont(new Font("Monospaced", Font.BOLD, 14));
        terminalArea.setEditable(false);
        terminalArea.setText("NeilOS Terminal v1.0\nType 'help' for commands\n\n");

        JScrollPane scrollPane = new JScrollPane(terminalArea);
        scrollPane.setBorder(BorderFactory.createLineBorder(Color.GREEN));
        panel.add(scrollPane, BorderLayout.CENTER);

        // Command Input
        JPanel commandPanel = new JPanel(new BorderLayout(5, 5));
        commandPanel.setBackground(new Color(30, 30, 40));
        
        JTextField commandField = new JTextField();
        commandField.setBackground(new Color(0, 0, 0));
        commandField.setForeground(Color.GREEN);
        commandField.setFont(new Font("Monospaced", Font.BOLD, 14));
        
        JButton execBtn = new JButton("▶ Execute");
        execBtn.setBackground(new Color(0, 120, 0));
        execBtn.setForeground(Color.WHITE);
        execBtn.setFont(new Font("Arial", Font.BOLD, 14));

        commandPanel.add(commandField, BorderLayout.CENTER);
        commandPanel.add(execBtn, BorderLayout.EAST);
        panel.add(commandPanel, BorderLayout.SOUTH);

        // Terminal command execution
        ActionListener executeCommand = e -> {
            String cmd = commandField.getText().trim().toLowerCase();
            if (cmd.isEmpty()) return;

            terminalArea.append("> " + cmd + "\n");
            
            String output;
            switch (cmd) {
                case "help":
                    output = "Available commands:\n" +
                             "  help     - Show this help\n" +
                             "  dir      - List files\n" +
                             "  files    - List files\n" +
                             "  version  - Show version\n" +
                             "  clear    - Clear terminal\n" +
                             "  status   - Show system status\n" +
                             "  users    - List bank users\n";
                    break;
                case "dir":
                case "files":
                    output = files.isEmpty() ? "No files found." : String.join("\n", files);
                    break;
                case "version":
                    output = "NeilOS Java Backend v1.0 with Graphics";
                    break;
                case "clear":
                    terminalArea.setText("NeilOS Terminal v1.0\nType 'help' for commands\n\n");
                    commandField.setText("");
                    return;
                case "status":
                    output = "System: Online\n" +
                             "Users: " + users.size() + "\n" +
                             "Files: " + files.size() + "\n" +
                             "Memory: " + formatMemory(Runtime.getRuntime().freeMemory());
                    break;
                case "users":
                    if (users.isEmpty()) {
                        output = "No users registered.";
                    } else {
                        StringBuilder sb = new StringBuilder("Users:\n");
                        for (Map.Entry<String, Integer> entry : users.entrySet()) {
                            sb.append("  ").append(entry.getKey()).append(": $").append(entry.getValue()).append("\n");
                        }
                        output = sb.toString();
                    }
                    break;
                default:
                    output = "❌ Unknown command: " + cmd + "\nType 'help' for available commands";
            }
            
            terminalArea.append(output + "\n\n");
            commandField.setText("");
            terminalArea.setCaretPosition(terminalArea.getDocument().getLength());
        };

        execBtn.addActionListener(executeCommand);
        commandField.addActionListener(executeCommand);

        return panel;
    }

    // =========================

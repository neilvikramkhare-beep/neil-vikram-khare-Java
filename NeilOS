        JButton refreshBtn = new JButton("🔄 Refresh");
        refreshBtn.setBackground(new Color(100, 100, 200));
        refreshBtn.setForeground(Color.WHITE);
        refreshBtn.setFont(new Font("Arial", Font.BOLD, 14));


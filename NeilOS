    private JPanel createAIPanel() {
        JPanel panel = new JPanel(new BorderLayout(10, 10));
        panel.setBackground(new Color(30, 30, 40));
        panel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));

        // AI Avatar
        JPanel headerPanel = new JPanel();
        headerPanel.setBackground(new Color(30, 30, 40));
        JLabel avatarLabel = new JLabel("🤖 NEIL AI ASSISTANT");
        avatarLabel.setFont(new Font("Arial", Font.BOLD, 24));
        avatarLabel.setForeground(Color.CYAN);
        headerPanel.add(avatarLabel);
        panel.add(headerPanel, BorderLayout.NORTH);

        // Chat Area
        JTextArea chatArea = new JTextArea(15, 50);
        chatArea.setBackground(new Color(20, 20, 30));
        chatArea.setForeground(Color.WHITE);
        chatArea.setFont(new Font("Arial", Font.PLAIN, 14));
        chatArea.setEditable(false);
        chatArea.setText("🤖 AI Assistant Ready!\n" +
                        "Commands: hello, scan, bank, help, weather, time\n\n");

        JScrollPane scrollPane = new JScrollPane(chatArea);
        scrollPane.setBorder(BorderFactory.createLineBorder(new Color(0, 200, 255)));
        panel.add(scrollPane, BorderLayout.CENTER);

        // Input Panel
        JPanel inputPanel = new JPanel(new BorderLayout(5, 5));
        inputPanel.setBackground(new Color(30, 30, 40));
        
        JTextField aiInput = new JTextField();
        aiInput.setBackground(new Color(20, 20, 30));
        aiInput.setForeground(Color.WHITE);
        aiInput.setFont(new Font("Arial", Font.PLAIN, 14));
        
        JButton sendBtn = new JButton("📤 Send");
        sendBtn.setBackground(new Color(0, 150, 200));
        sendBtn.setForeground(Color.WHITE);
        sendBtn.setFont(new Font("Arial", Font.BOLD, 14));

        inputPanel.add(aiInput, BorderLayout.CENTER);
        inputPanel.add(sendBtn, BorderLayout.EAST);
        panel.add(inputPanel, BorderLayout.SOUTH);

        // AI Response
        ActionListener aiAction = e -> {
            String message = aiInput.getText().trim();
            if (message.isEmpty()) return;
            
            chatArea.append("👤 You: " + message + "\n");
            
            String response = "🤖 Neil AI: ";
            String msgLower = message.toLowerCase();
            
            if (msgLower.contains("hello") || msgLower.contains("hi")) {
                response += "Hello user! How can I assist you today? 😊";
            } else if (msgLower.contains("scan") || msgLower.contains("security")) {
                response += "🔒 Opening Cyber Security Center... System is secure!";
            } else if (msgLower.contains("bank")) {
                response += "💰 Opening Banking System... Access granted!";
            } else if (msgLower.contains("help")) {
                response += "💡 Available commands: hello, scan, bank, weather, time, status, clear";
            } else if (msgLower.contains("weather")) {
                response += "🌤️ Weather in NeilOS City: 72°F, Partly Cloudy";
            } else if (msgLower.contains("time")) {
                response += "🕐 " + new Date().toString();
            } else if (msgLower.contains("clear")) {
                chatArea.setText("");
                aiInput.setText("");
                return;
            } else if (msgLower.contains("status")) {
                response += "🟢 System Online | Users: " + users.size() + 
                           " | Files: " + files.size();
            } else {
                response += "I didn't understand. Try: hello, scan, bank, weather, time, help";
            }
            
            chatArea.append(response + "\n\n");
            aiInput.setText("");
            chatArea.setCaretPosition(chatArea.getDocument().getLength());
        };

        sendBtn.addActionListener(aiAction);
        aiInput.addActionListener(aiAction);

        return panel;
    }

    // =========================

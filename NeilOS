    private JPanel createSecurityPanel() {
        JPanel panel = new JPanel(new GridLayout(3, 2, 15, 15));
        panel.setBackground(new Color(30, 30, 40));
        panel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));

        String[][] securityItems = {
            {"🛡️", "Firewall", "ACTIVE", Color.GREEN},
            {"🔑", "Encryption", "AES-256", Color.CYAN},
            {"🦠", "Anti-Virus", "Up to Date", Color.GREEN},
            {"🌐", "Network", "Secure", Color.GREEN},
            {"📡", "Intrusion Detection", "Monitoring", Color.YELLOW},
            {"🔒", "Threat Level", "LOW", Color.GREEN}
        };

        for (String[] item : securityItems) {
            JPanel card = new JPanel(new BorderLayout());
            card.setBackground(new Color(50, 50, 70));
            card.setBorder(BorderFactory.createLineBorder(new Color(100, 100, 130), 2));
            
            JLabel iconLabel = new JLabel(item[0] + " " + item[1]);
            iconLabel.setFont(new Font("Arial", Font.BOLD, 16));
            iconLabel.setForeground(Color.WHITE);
            
            JLabel statusLabel = new JLabel(item[2]);
            Color color;
            switch (item[3].toString()) {
                case "GREEN": color = Color.GREEN; break;
                case "CYAN": color = Color.CYAN; break;
                case "YELLOW": color = Color.YELLOW; break;
                default: color = Color.WHITE;
            }
            statusLabel.setForeground(color);
            statusLabel.setFont(new Font("Arial", Font.BOLD, 18));
            statusLabel.setHorizontalAlignment(SwingConstants.RIGHT);
            
            card.add(iconLabel, BorderLayout.WEST);
            card.add(statusLabel, BorderLayout.EAST);
            panel.add(card);
        }

        return panel;
    }


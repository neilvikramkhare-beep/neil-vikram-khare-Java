    // =========================

    private JPanel createMonitorPanel() {
        JPanel panel = new JPanel(new GridLayout(4, 2, 15, 15));
        panel.setBackground(new Color(30, 30, 40));
        panel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));

        Runtime runtime = Runtime.getRuntime();
        long uptime = ManagementFactory.getRuntimeMXBean().getUptime();

        String[][] monitorData = {
            {"⏱️ Uptime", formatUptime()},
            {"💾 Free Memory", formatMemory(runtime.freeMemory())},
            {"📀 Total Memory", formatMemory(runtime.totalMemory())},
            {"⚙️ Processors", String.valueOf(runtime.availableProcessors())},
            {"🔄 Max Memory", formatMemory(runtime.maxMemory())},
            {"📊 Used Memory", formatMemory(runtime.totalMemory() - runtime.freeMemory())},
            {"📡 API Status", "Online"},
            {"🚀 System", System.getProperty("os.name")}
        };

        for (String[] data : monitorData) {
            JPanel card = new JPanel(new BorderLayout(10, 5));
            card.setBackground(new Color(50, 50, 70));
            card.setBorder(BorderFactory.createLineBorder(new Color(100, 100, 130), 2));
            
            JLabel label = new JLabel(data[0]);
            label.setFont(new Font("Arial", Font.BOLD, 16));
            label.setForeground(Color.WHITE);
            
            JLabel value = new JLabel(data[1]);
            value.setFont(new Font("Arial", Font.BOLD, 18));
            value.setForeground(Color.CYAN);
            value.setHorizontalAlignment(SwingConstants.RIGHT);
            
            card.add(label, BorderLayout.WEST);
            card.add(value, BorderLayout.EAST);
            panel.add(card);
        }

        return panel;
    }

    // =========================
    // HELPER METHODS
    // =========================

    private String formatMemory(long bytes) {
        if (bytes < 1024) return bytes + " B";
        if (bytes < 1024 * 1024) return (bytes / 1024) + " KB";
        if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)) + " MB";
        return (bytes / (1024 * 1024 * 1024)) + " GB";
    }

    private String formatUptime() {
        long uptime = ManagementFactory.getRuntimeMXBean().getUptime();
        long seconds = uptime / 1000;
        long minutes = seconds / 60;
        long hours = minutes / 60;
        long days = hours / 24;
        
        if (days > 0) return days + "d " + (hours % 24) + "h";
        if (hours > 0) return hours + "h " + (minutes % 60) + "m";
        if (minutes > 0) return minutes + "m " + (seconds % 60) + "s";
        return seconds + "s";
    }


    private JPanel createDashboardPanel() {
        JPanel panel = new JPanel(new GridLayout(3, 3, 15, 15));
        panel.setBackground(new Color(30, 30, 40));
        panel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));

        String[][] stats = {
            {"🖥️", "System Status", "Running"},
            {"👥", "Active Users", String.valueOf(users.size())},
            {"📁", "Total Files", String.valueOf(files.size())},
            {"🏥", "Patients", String.valueOf(patients.size())},
            {"🧠", "AI Status", "Ready"},
            {"🔒", "Firewall", "Active"},
            {"💾", "Memory Free", formatMemory(Runtime.getRuntime().freeMemory())},
            {"📡", "API Status", "Online"},
            {"⚡", "Uptime", formatUptime()}
        };

        for (String[] stat : stats) {
            JPanel card = new JPanel();
            card.setLayout(new BoxLayout(card, BoxLayout.Y_AXIS));
            card.setBackground(new Color(60, 60, 80));
            card.setBorder(BorderFactory.createLineBorder(new Color(100, 100, 130), 2));
            card.setPreferredSize(new Dimension(200, 100));

            JLabel iconLabel = new JLabel(stat[0]);
            iconLabel.setFont(new Font("Segoe UI", Font.PLAIN, 30));
            iconLabel.setAlignmentX(Component.CENTER_ALIGNMENT);

            JLabel titleLabel = new JLabel(stat[1]);
            titleLabel.setFont(new Font("Arial", Font.BOLD, 14));
            titleLabel.setForeground(Color.LIGHT_GRAY);
            titleLabel.setAlignmentX(Component.CENTER_ALIGNMENT);

            JLabel valueLabel = new JLabel(stat[2]);
            valueLabel.setFont(new Font("Arial", Font.BOLD, 18));
            valueLabel.setForeground(Color.CYAN);
            valueLabel.setAlignmentX(Component.CENTER_ALIGNMENT);

            card.add(Box.createVerticalGlue());
            card.add(iconLabel);
            card.add(titleLabel);
            card.add(valueLabel);
            card.add(Box.createVerticalGlue());

            panel.add(card);
        }

        return panel;
    }

    // =========================
    // BANKING PANEL
    // =========================

    private JPanel createBankingPanel() {
        JPanel panel = new JPanel(new BorderLayout(10, 10));
        panel.setBackground(new Color(30, 30, 40));
        panel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));

        // Input Panel
        JPanel inputPanel = new JPanel(new GridLayout(3, 2, 10, 10));
        inputPanel.setBackground(new Color(30, 30, 40));
        inputPanel.setBorder(BorderFactory.createTitledBorder(
            BorderFactory.createLineBorder(Color.CYAN),
            "Banking Operations",
            TitledBorder.CENTER,
            TitledBorder.TOP,
            new Font("Arial", Font.BOLD, 16),
            Color.CYAN
        ));

        JLabel userLabel = new JLabel("Username:");
        userLabel.setForeground(Color.WHITE);
        JTextField userField = new JTextField(15);

        JLabel amountLabel = new JLabel("Amount:");
        amountLabel.setForeground(Color.WHITE);
        JTextField amountField = new JTextField(15);

        inputPanel.add(userLabel);
        inputPanel.add(userField);
        inputPanel.add(amountLabel);
        inputPanel.add(amountField);

        JButton depositBtn = new JButton("💰 Deposit");
        depositBtn.setBackground(new Color(0, 150, 0));
        depositBtn.setForeground(Color.WHITE);
        depositBtn.setFont(new Font("Arial", Font.BOLD, 14));

        JButton withdrawBtn = new JButton("💳 Withdraw");
        withdrawBtn.setBackground(new Color(200, 50, 50));
        withdrawBtn.setForeground(Color.WHITE);
        withdrawBtn.setFont(new Font("Arial", Font.BOLD, 14));

        inputPanel.add(depositBtn);
        inputPanel.add(withdrawBtn);

        panel.add(inputPanel, BorderLayout.NORTH);

        // Output Area
        JTextArea outputArea = new JTextArea();
        outputArea.setBackground(new Color(20, 20, 30));
        outputArea.setForeground(Color.GREEN);
        outputArea.setFont(new Font("Monospaced", Font.PLAIN, 14));
        outputArea.setEditable(false);
        outputArea.setText("Welcome to NeilOS Banking System\n");

        JScrollPane scrollPane = new JScrollPane(outputArea);
        scrollPane.setBorder(BorderFactory.createTitledBorder(
            BorderFactory.createLineBorder(Color.GREEN),
            "Transaction History",
            TitledBorder.CENTER,
            TitledBorder.TOP,
            new Font("Arial", Font.BOLD, 14),
            Color.GREEN
        ));
        panel.add(scrollPane, BorderLayout.CENTER);

        // Action Listeners
        depositBtn.addActionListener(e -> {
            try {
                String user = userField.getText().trim();
                int amount = Integer.parseInt(amountField.getText().trim());
                if (user.isEmpty() || amount <= 0) {
                    outputArea.append("❌ Invalid input!\n");
                    return;
                }
                users.putIfAbsent(user, 0);
                users.put(user, users.get(user) + amount);
                outputArea.append("✅ Deposited $" + amount + " to " + user + 
                                 " | Balance: $" + users.get(user) + "\n");
            } catch (NumberFormatException ex) {
                outputArea.append("❌ Please enter a valid number!\n");
            }
        });

        withdrawBtn.addActionListener(e -> {
            try {
                String user = userField.getText().trim();
                int amount = Integer.parseInt(amountField.getText().trim());
                if (user.isEmpty() || amount <= 0) {
                    outputArea.append("❌ Invalid input!\n");
                    return;
                }
                users.putIfAbsent(user, 0);
                int balance = users.get(user);
                if (balance < amount) {
                    outputArea.append("❌ Insufficient balance for " + user + "\n");
                } else {
                    users.put(user, balance - amount);
                    outputArea.append("💳 Withdrew $" + amount + " from " + user + 
                                    " | Balance: $" + users.get(user) + "\n");
                }
            } catch (NumberFormatException ex) {
                outputArea.append("❌ Please enter a valid number!\n");
            }
        });

        // Show user list button
        JButton listBtn = new JButton("👥 Show Users");
        listBtn.setBackground(new Color(100, 100, 200));
        listBtn.setForeground(Color.WHITE);
        listBtn.setFont(new Font("Arial", Font.BOLD, 14));
        
        JPanel buttonPanel = new JPanel();
        buttonPanel.setBackground(new Color(30, 30, 40));
        buttonPanel.add(listBtn);
        panel.add(buttonPanel, BorderLayout.SOUTH);

        listBtn.addActionListener(e -> {
            outputArea.append("\n--- Users List ---\n");
            if (users.isEmpty()) {
                outputArea.append("No users registered.\n");
            } else {
                for (Map.Entry<String, Integer> entry : users.entrySet()) {
                    outputArea.append("👤 " + entry.getKey() + " | Balance: $" + entry.getValue() + "\n");
                }
            }
            outputArea.append("-----------------\n");
        });

        return panel;
    }


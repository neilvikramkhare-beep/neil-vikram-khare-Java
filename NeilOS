                patientModel.addElement(name + " | Age: " + age + " | " + ailment);
                
                nameField.setText("");
                ageField.setText("");
                ailmentField.setText("");
                contactField.setText("");
            }
        });

        refreshBtn.addActionListener(e -> {
            patientModel.clear();
            for (Map<String, Object> p : patients) {
                patientModel.addElement(p.get("name") + " | Age: " + p.get("age") + 
                                      " | " + p.get("ailment"));
            }
        });

        return panel;

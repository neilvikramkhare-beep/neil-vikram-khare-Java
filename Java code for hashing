import java.util.HashSet;
import java.util.Iterator;
import java.util.Set;
import java.util.TreeSet;
public class Hashing {
    public static void main(String[] args) {
        HashSet<String> set = new HashSet<>();
        set.add("apple");
        set.add("banana");
        set.add("orange");
        System.out.println("HashSet: " + set);
        if (set.contains("banana")) {
            System.out.println("Banana is in the set.");
        }
        set.remove("orange");
        System.out.println("After removing orange: " + set);
        if(set.contains("grape")) {
            System.out.println("Grape is in the set.");
        } else {
            System.out.println("Grape is not in the set.");
        }
        if(set.isEmpty()) {
            System.out.println("The set is empty.");
        } else {
            System.out.println("The set is not empty.");
        }
        if(set.size() > 0) {
            System.out.println("The set has " + set.size() + " elements.");
        } else {
            System.out.println("The set is empty.");
        }
        System.out.println(set.remove("apple") ? "Apple removed." : "Apple not found.");
        System.out.println(set);
        if (!set.isEmpty()) {
            System.out.println(set.iterator().next());
        }
    }
}
